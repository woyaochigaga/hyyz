AI_CHAT_SYSTEM_PROMPT_EN = ""

# -----------------------------------------------------------------------------
# Storage with aws s3 sdk (Compatible with Tencent Cloud COS)
# https://docs.aws.amazon.com/s3/index.html
# Tencent Cloud COS: https://cloud.tencent.com/document/product/436
# -----------------------------------------------------------------------------
STORAGE_ENDPOINT = "https://cos.ap-shanghai.myqcloud.com"
STORAGE_REGION = "ap-shanghai"
STORAGE_ACCESS_KEY = ""
STORAGE_SECRET_KEY = ""
STORAGE_BUCKET = ""
# Public URL prefix for objects; trimmed when building links. Also exposed to the client as NEXT_PUBLIC_STORAGE_DOMAIN (see next.config.mjs) for avatar proxy.
STORAGE_DOMAIN = ""
