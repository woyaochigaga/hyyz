@startuml
title 杭艺云展支付积分模块图
scale max 700 width
top to bottom direction

skinparam shadowing false
skinparam backgroundColor white
skinparam defaultFontName PingFang SC
skinparam defaultFontSize 11
skinparam dpi 150
skinparam wrapWidth 160
skinparam maxMessageSize 160
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam ArrowColor #666666
skinparam ArrowThickness 1
skinparam packageBorderColor #8A8A8A
skinparam packageBackgroundColor #FCFCFC
skinparam packageFontStyle bold
skinparam packageFontSize 13
skinparam rectangle {
  BorderColor #444444
  BackgroundColor #FCFCFC
  FontSize 11
}

rectangle "支付积分模块" as pay_module

package "前台能力" {
  rectangle "购买入口\n套餐选择 / 结算触发" as checkout_ui
  rectangle "支付结果页\n成功回跳" as pay_result
  rectangle "我的积分页\n余额与记录" as credits_page
}

package "支付链路" {
  rectangle "结算接口\n/api/checkout" as checkout_api
  rectangle "Stripe Checkout" as stripe_checkout
  rectangle "Webhook 回调\n/api/stripe-notify" as webhook
}

package "账户与积分" {
  rectangle "订单服务\n创建订单 / 更新状态" as order_service
  rectangle "积分服务\n增加 / 扣减 / 查询" as credit_service
  rectangle "推广返佣\naffiliate" as affiliate
  rectangle "订单表 + 积分表" as pay_db
}

pay_module --> checkout_ui
pay_module --> pay_result
pay_module --> credits_page

checkout_ui --> checkout_api
checkout_api --> stripe_checkout
stripe_checkout --> webhook

checkout_api --> order_service
webhook --> order_service
order_service --> credit_service
order_service --> affiliate
credit_service --> pay_db
order_service --> pay_db
credits_page --> credit_service

@enduml
